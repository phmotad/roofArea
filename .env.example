# ========== OBRIGATÓRIO ==========
# PostgreSQL com extensão PostGIS. Sem isto a API não persiste resultados.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/roof_db

# Optional: sync URL for Alembic
DATABASE_SYNC_URL=postgresql://user:password@localhost:5432/roof_db

# Buffer radius in meters for ortho/DSM clip
GEO_BUFFER_METERS=35

# Base imagery: Mapbox Satellite (recommended). Get token at https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=

# Alternative: custom URL that returns PNG for the area (orthophoto, etc.); used if Mapbox not set
ORTHO_TILE_URL=

# LIDAR/DSM: path to a single .tif file OR a folder of GeoTIFFs (picks the tile that contains the point)
LIDAR_DGT_PATH=C:/Projects/roofApi/lidar
LIDAR_PNOA_PATH=C:/Projects/roofApi/lidar

# DeepLabV3+ modelo principal (multiclasse: fundo, águas, claraboia, divisória, laje)
SEGMENTATION_MODEL_PATH=./models/deeplabv3_roof_multiclass.pt
SEGMENTATION_NUM_CLASSES=5
SEGMENTATION_PROB_THRESHOLD=0.6
SEGMENTATION_DEEPLAB_BACKBONE=resnet50

# Opcional: modelo de linhas (U-Net) para refinar divisão em águas (cumeeiras/arestas)
SEGMENTATION_LINES_MODEL_PATH=./models/unet_lines.pt

# Output: include base64 image in JSON
OUTPUT_IMAGE_BASE64=false

# Cache TTL seconds (0 = disabled)
CACHE_TTL_SECONDS=86400

# Minimum roof area in m² to consider valid (ignores small noise components)
MIN_ROOF_AREA_M2=10

# Focus on one building: only keep águas whose centroid is within this distance (m) of the point. 0 = disabled.
# Use e.g. 25 when the mask merges two nearby roofs so only the roof under the point is returned.
MAX_ROOF_DISTANCE_FROM_POINT_M=0

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
